# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your actual values
# NEVER commit secrets.toml to version control!

# Database Configuration
[database]
host = "localhost"
port = 5433
name = "flott_streamlit"
user = "postgres"
password = "your_database_password"

# MyOrg API Configuration
[myorg_api]
# Base URL for MyOrg API (do not include /api/entity/inn)
base_url = "https://api.myorg.uz"

# JWT Bearer token from MyOrg (without "Bearer" prefix)
# You can get this from MyOrg API dashboard
bearer_token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# IMPORTANT NOTES:
# 1. The actual endpoint used is: {base_url}/api/entity/inn/{inn}
# 2. The auth header format is: token: Bearer {bearer_token}
# 3. Keep your bearer token secure and never commit secrets.toml to git!

# Example with real token format:
# [myorg_api]
# base_url = "https://api.myorg.uz"
# bearer_token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6OTIsImlhdCI6MTc1NzQ5NTM4OSwiZXhwIjoyMDczMDcxMzg5fQ.BSwiQKrStv_Gzl5lEMG8YmRyK2uFkw--rYUEg9eRkts"
